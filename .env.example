# LLM API target for the `npm run serve` CORS proxy (supports http/https).
API_TARGET=https://aigateway.xx.com

# Optional dev defaults — if present, the Config panel is pre-populated with
# these when no localStorage config exists. Copy to .env.local (gitignored).
# VITE_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# VITE_OPENAI_API_KEY=sk-...
# VITE_OPENAI_MODEL_ID=openai/gpt-5-nano
